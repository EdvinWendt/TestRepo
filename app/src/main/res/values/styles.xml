<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TestRepo_DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/dialog_fade_in</item>
        <item name="android:windowExitAnimation">@anim/dialog_fade_out</item>
    </style>

    <style name="TestRepo_FullScreenDialog.Blue" parent="Theme.TestRepo.Blue">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">?attr/colorSurface</item>
        <item name="android:windowAnimationStyle">@style/TestRepo_DialogAnimation</item>
    </style>

    <style name="TestRepo_FullScreenDialog.Green" parent="Theme.TestRepo.Green">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">?attr/colorSurface</item>
        <item name="android:windowAnimationStyle">@style/TestRepo_DialogAnimation</item>
    </style>

    <style name="TestRepo_FullScreenDialog" parent="TestRepo_FullScreenDialog.Blue" />
</resources>
